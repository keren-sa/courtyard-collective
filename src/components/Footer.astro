---
const year = 2026;
---

<footer
  class="bg-[color:var(--color-dark)] text-[color:var(--color-on-dark)] px-5 md:px-20 pt-16 pb-28 md:pb-16"
>
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row md:justify-between gap-12 mb-12">
      <div class="max-w-sm">
        <div class="font-display text-3xl md:text-4xl mb-4">
          The Courtyard Collective
        </div>
        <p class="opacity-75 leading-relaxed">
          Tbilisi apartments sold by their courtyards — because the flat is where
          you sleep, and the courtyard is where you're known.
        </p>
        <p class="caps mt-6 opacity-60">
          Tbilisi, Georgia · Mon–Sat 10am–7pm · Courtyard visits by appointment
        </p>
      </div>

      <div class="grid grid-cols-2 gap-x-12 gap-y-3 caps opacity-90">
        <a href="/courtyards" class="hover:opacity-100 opacity-80">Apartments</a>
        <a href="/communities" class="hover:opacity-100 opacity-80">Courtyards</a>
        <a href="/meet-the-neighbors" class="hover:opacity-100 opacity-80">Neighbors</a>
        <a href="/about" class="hover:opacity-100 opacity-80">About</a>
        <a href="/inquire" class="hover:opacity-100 opacity-80">Inquire</a>
        <a href="mailto:hello@courtyardcollective.tbilisi" class="hover:opacity-100 opacity-80">Contact</a>
      </div>
    </div>

    <div
      class="border-t border-[color:var(--color-on-dark)]/20 pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4 text-sm opacity-70"
    >
      <div>
        © {year} The Courtyard Collective. Built for Tbilisi's shared histories.
      </div>
      <div class="flex gap-5">
        <a href="https://instagram.com/courtyardcollective.tbilisi" class="hover:opacity-100">@courtyardcollective.tbilisi</a>
        <a href="https://instagram.com/thesharedtable" class="hover:opacity-100">@thesharedtable</a>
      </div>
    </div>
  </div>
</footer>

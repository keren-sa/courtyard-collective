---
import GrapevineTendril from "./GrapevineTendril.astro";
import GossipMeter from "./GossipMeter.astro";

interface Props {
  name: string;
  grapevineAgeYears: number;
  gossipRating: number;
  shortLine?: string;
  href?: string;
  compact?: boolean;
}
const { name, grapevineAgeYears, gossipRating, shortLine, href, compact = false } = Astro.props;

const Wrapper = href ? "a" : "div";
---

<Wrapper
  href={href}
  class:list={[
    "block bg-[color:var(--color-surface)] border border-[color:var(--color-border)] p-6 md:p-8 relative overflow-hidden group",
    href && "transition-colors hover:border-[color:var(--color-primary)]",
  ]}
>
  <GrapevineTendril ageYears={grapevineAgeYears} />

  <div class="relative">
    <div class="caps text-[color:var(--color-text-muted)] mb-2">Courtyard</div>
    <h3 class="font-display text-2xl md:text-3xl text-[color:var(--color-primary)] leading-tight mb-4">
      {name}
    </h3>

    {shortLine && !compact && (
      <p class="text-sm italic text-[color:var(--color-text-muted)] mb-6 max-w-xs">
        {shortLine}
      </p>
    )}

    <div class="space-y-4 pt-4 border-t border-[color:var(--color-border)]/60">
      <div class="flex items-baseline justify-between gap-4">
        <span class="caps text-[color:var(--color-text-muted)]">Grapevine age</span>
        <span class="font-display text-xl text-[color:var(--color-text)]">{grapevineAgeYears} years</span>
      </div>
      <div>
        <div class="flex items-center justify-between caps text-[color:var(--color-text-muted)] mb-2">
          <span>Gossip rating</span>
          <span class="not-italic">{gossipRating} / 10</span>
        </div>
        <GossipMeter rating={gossipRating} />
      </div>
    </div>
  </div>
</Wrapper>

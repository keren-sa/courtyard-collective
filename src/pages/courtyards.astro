---
import Layout from "../layouts/Layout.astro";
import ListingCard from "../components/ListingCard.astro";
import { apartments as staticApartments, type Apartment } from "../data/content";
import { fetchCollection } from "../lib/wix";

const { data: apartments, source } = await fetchCollection<Apartment>(
  "Apartments",
  staticApartments,
  { sortField: "order" },
);

const residenceJsonLd = apartments.map((apt) => ({
  "@context": "https://schema.org",
  "@type": "Residence",
  name: apt.title,
  description: apt.courtyardStory,
  url: `/courtyards/${apt.slug}`,
  numberOfRooms: apt.rooms,
  floorSize: { "@type": "QuantitativeValue", value: apt.squareMeters, unitCode: "MTK" },
  address: { "@type": "PostalAddress", addressLocality: "Tbilisi", addressCountry: "GE" },
  offers: { "@type": "Offer", price: apt.price, priceCurrency: "USD" },
}));

const aspects = ["aspect-[4/5]", "aspect-[3/4]", "aspect-[16/10]", "aspect-[4/3]", "aspect-[4/5]", "aspect-[16/9]"];
const colSpans = [
  "md:col-span-7",
  "md:col-span-4 md:col-start-9 md:mt-16",
  "md:col-span-5",
  "md:col-span-6 md:col-start-7 md:-mt-16",
  "md:col-span-4",
  "md:col-span-7 md:col-start-6",
];
---

<Layout
  title="The Courtyards · The Courtyard Collective"
  description="Six Tbilisi courtyard apartments currently available. Each one comes wrapped in its courtyard, its neighbors, and its story."
  jsonLd={residenceJsonLd}
>
  <section class="px-5 md:px-20 pt-16 md:pt-24 pb-12 md:pb-16">
    <div class="max-w-5xl">
      <div class="caps text-[color:var(--color-text-muted)] mb-4">The Courtyards</div>
      <h1 class="font-display text-4xl md:text-6xl text-[color:var(--color-primary)] leading-[1.04]">
        Six apartments,
        <span class="italic block">each one already wrapped in a courtyard.</span>
      </h1>
      <p class="mt-8 text-lg text-[color:var(--color-text)]/85 leading-relaxed measure">
        These are the flats we have open this season. The price is for the apartment; the courtyard,
        the grapevine, and the Sunday table come with belonging, not money.
      </p>
    </div>
  </section>

  <section class="px-5 md:px-20 pb-24 md:pb-32">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-y-16 md:gap-x-8">
      {apartments.map((apt, i) => (
        <div class:list={[colSpans[i % colSpans.length]]}>
          <ListingCard apt={apt} aspect={aspects[i % aspects.length]} loading={i < 2 ? "eager" : "lazy"} />
        </div>
      ))}
    </div>
  </section>

  <section class="px-5 md:px-20 py-20 md:py-24 bg-[color:var(--color-dark)] text-[color:var(--color-on-dark)] text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl mb-6 leading-tight">
        See one that fits how you like to live?
      </h2>
      <p class="opacity-80 mb-8 leading-relaxed">
        We'll set up a sit-down in the courtyard before any contract talk.
      </p>
      <a
        href="/inquire"
        class="inline-flex items-center justify-center px-8 py-4 bg-[color:var(--color-on-dark)] text-[color:var(--color-primary)] uppercase tracking-widest text-xs font-semibold rounded-sm hover:opacity-90"
      >
        Ask about a courtyard
      </a>
    </div>
  </section>
</Layout>

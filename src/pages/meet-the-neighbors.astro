---
import Layout from "../layouts/Layout.astro";
import Picture from "../components/Picture.astro";

const steps = [
  { n: "01", title: "Sit in the courtyard.", body: "Before the apartment, before the price, before the paperwork — we meet you in the well. We bring coffee. You watch how the light moves across the balconies. Half an hour is usually enough to know if it's your kind of quiet, or your kind of loud.", image: "apt-long-table", imageAlt: "Long table under grapevines, ready for an unhurried afternoon." },
  { n: "02", title: "The soft introduction.", body: "We knock on two or three doors. The neighbors who answer aren't here to interview you — they're here to be met. Most of the time someone produces wine, or jam, or a story about the building's plumbing.", image: "meet-tea", imageAlt: "Two people sharing tea on a vine-shaded balcony." },
  { n: "03", title: "Sharing the story.", body: "If everyone's still around when the sun gets lower, we sit at the long table. The courtyard's story comes out — who planted the vine, whose grandmother kept the shared ladder, which year someone tried to paint the door blue and was politely undone the next morning.", image: "apt-grapevine-flat", imageAlt: "Tall French doors open onto a balcony at golden hour." },
  { n: "04", title: "The nod of approval.", body: "Both ways. You decide whether this is the courtyard you want to be known in. They decide whether you're someone they want to know. Most of the time it's a quiet yes from both sides. When it isn't, we keep looking — no bad feelings.", image: "apt-shared-ladder", imageAlt: "View from a wooden balcony into a multi-level Tbilisi courtyard." },
  { n: "05", title: "Then we talk paperwork.", body: "Notary, deed, bank, registration. Three to six weeks usually. We walk you through every form. By the time you sign, the neighbors are already waving from across the well — they've decided you live here.", image: "apt-stairwell-cat", imageAlt: "Wrought-iron spiral staircase among vines." },
];
---

<Layout
  title="Meet the Neighbors · The Courtyard Collective"
  description="The step-by-step process of meeting a Tbilisi courtyard — and its people — before any contract talk."
>
  <section class="px-5 md:px-20 pt-16 md:pt-24 pb-12 md:pb-16">
    <div class="max-w-5xl">
      <div class="caps text-[color:var(--color-text-muted)] mb-4">Meet the Neighbors</div>
      <h1 class="font-display text-4xl md:text-6xl text-[color:var(--color-primary)] leading-[1.04]">
        Unlocking the spirit
        <span class="italic block">of the courtyard.</span>
      </h1>
      <p class="mt-8 text-lg text-[color:var(--color-text)]/85 leading-relaxed measure">
        We arrange a sit-down in the courtyard before any contract talk. This is how that goes —
        slow on purpose, mutual on principle. Nobody signs until everyone's had a glass and a
        conversation.
      </p>
    </div>
  </section>

  <section class="px-5 md:px-20 pb-24 md:pb-32">
    <ol class="max-w-5xl mx-auto space-y-20 md:space-y-28">
      {steps.map((s, i) => {
        const reverse = i % 2 === 1;
        return (
          <li class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
            <div class:list={["md:col-span-7", reverse && "md:order-2"]}>
              <Picture
                name={s.image}
                alt={s.imageAlt}
                sizes="(min-width: 768px) 58vw, 100vw"
                class="w-full aspect-[4/3] object-cover border border-[color:var(--color-border)]"
              />
            </div>
            <div class:list={["md:col-span-5", reverse && "md:order-1"]}>
              <span class="font-display italic text-5xl md:text-6xl text-[color:var(--color-primary)] opacity-70 block mb-4">
                {s.n}
              </span>
              <h3 class="font-display text-3xl md:text-4xl text-[color:var(--color-primary)] leading-tight mb-4">
                {s.title}
              </h3>
              <p class="text-[color:var(--color-text)]/85 leading-relaxed measure">{s.body}</p>
            </div>
          </li>
        );
      })}
    </ol>
  </section>

  <section class="px-5 md:px-20 py-20 md:py-24 bg-[color:var(--color-surface)] border-t border-[color:var(--color-border)] text-center">
    <div class="max-w-2xl mx-auto">
      <h2 class="font-display text-3xl md:text-4xl mb-6 leading-tight text-[color:var(--color-primary)]">
        You don't have to walk in alone.
      </h2>
      <p class="text-[color:var(--color-text)]/85 mb-8 leading-relaxed">
        We publish the gossip rating and the grapevine age before the meeting so you walk in
        already knowing the temperature.
      </p>
      <a href="/inquire" class="btn-primary uppercase tracking-widest text-xs">
        Start your introduction
      </a>
    </div>
  </section>
</Layout>

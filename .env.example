# Wix Headless OAuth client — generated by `npm create @wix/new headless`.
# Run `wix env pull` to populate these into .env.local automatically.
WIX_CLIENT_ID=
WIX_CLIENT_SECRET=
WIX_CLIENT_INSTANCE_ID=
WIX_CLOUD_PROVIDER=KUBERNETES

# Optional: API key with Wix Data scope (only needed to run scripts/seed-cms.mjs).
# Generate at https://manage.wix.com/account/api-keys
WIX_API_KEY=

# No extra env vars needed for email — the confirmation email is sent by a
# Wix Automation you configure in the dashboard:
#   Wix Dashboard → Automations → New automation
#     Trigger:  "Contact submits a form"  (or label-based trigger)
#     Action:   "Send an email"  (compose your template here)
# The form already submits the buyer to Wix CRM via @wix/crm, which is what
# fires the automation.

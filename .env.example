# Wix Headless OAuth client — generated by `npm create @wix/new headless`.
# Run `wix env pull` to populate these into .env.local automatically.
WIX_CLIENT_ID=
WIX_CLIENT_SECRET=
WIX_CLIENT_INSTANCE_ID=
WIX_CLOUD_PROVIDER=KUBERNETES

# Optional: API key with Wix Data scope (only needed to run scripts/seed-cms.mjs).
# Generate at https://manage.wix.com/account/api-keys
WIX_API_KEY=

# Resend transactional email — sends the inquiry confirmation to the buyer.
# Sign up at https://resend.com (free, no card). API key starts with "re_".
# Without RESEND_API_KEY the form still works; the email send just no-ops.
RESEND_API_KEY=
# Optional. Defaults to "The Courtyard Collective <onboarding@resend.dev>".
# After domain verification, swap to e.g. "neighbor@courtyard-collective.com".
RESEND_FROM=
# Optional reply-to address (so buyer replies land in your inbox).
RESEND_REPLY_TO=

# Wix Headless OAuth client — generated by `npm create @wix/new headless`.
# Run `wix env pull` to populate these into .env.local automatically.
WIX_CLIENT_ID=
WIX_CLIENT_SECRET=
WIX_CLIENT_INSTANCE_ID=
WIX_CLOUD_PROVIDER=KUBERNETES

# Optional: API key with Wix Data scope (only needed to run scripts/seed-cms.mjs).
# Generate at https://manage.wix.com/account/api-keys
WIX_API_KEY=

# No additional env vars needed. The form writes directly to the Wix CMS
# "Inquiries" collection from the browser using the visitor OAuth token
# (WIX_CLIENT_ID above). The collection must have insert: ANYONE permissions.
# For email confirmations, set up a Wix Automation in the dashboard:
#   Automations → New automation
#     Trigger: "New item in collection: Inquiries"
#     Action: "Send an email" (to {{email}} field)
